{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RelayTerm",
  "version": "0.0.0",
  "identifier": "cc.js-node.relayterm.desktop",
  "build": {
    "frontendDist": "../../web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --filter @relayterm/web dev",
    "beforeBuildCommand": "pnpm --filter @relayterm/web build"
  },
  "app": {
    "windows": [
      {
        "title": "RelayTerm",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
