# RelayTerm — example deployment env file.
#
# Copy this file to `.env` next to `docker-compose.example.yml` (or
# `docker-compose.yml`) and fill in real values. Do NOT commit a `.env`
# with real secrets — the repo's `.gitignore` covers `.env` already.
#
# Every secret here can also be supplied via `docker secrets`, a
# systemd `EnvironmentFile=`, or whatever your host's secret store is.
# Compose's `environment:` block reads these names; nothing in this
# file is RelayTerm-specific syntax.
#
# Generate fresh 32-byte base64 keys with:
#
#   openssl rand -base64 32
#
# Generate a URL-safe bootstrap token with:
#
#   openssl rand -base64 32 | tr '+/' '-_' | tr -d '='


# --- Postgres ---------------------------------------------------------------

POSTGRES_USER=relayterm
POSTGRES_PASSWORD=CHANGE_ME_postgres_password
POSTGRES_DB=relayterm


# --- Backend: auth ----------------------------------------------------------

# Production envelope. Boot-time validator requires:
#   * a non-empty allowed_origins list
#   * cookie_secure=true
#   * exactly one session signing key source
#
# `dev` is for local development only. NEVER ship `dev` to a public
# host.
RELAYTERM_AUTH__MODE=production

# Public origin(s) the browser will use, comma-separated. Each entry
# is an exact `scheme://host[:port]` — no trailing slash, no path. The
# CSRF guard does byte-equality. Configure the lower-case form the
# browser actually sends.
RELAYTERM_AUTH__ALLOWED_ORIGINS=https://relayterm.example.com

# `Set-Cookie: ...; Secure`. MUST be true in production.
RELAYTERM_AUTH__COOKIE_SECURE=true

# 32 random bytes, base64. CHANGE THIS.
#   openssl rand -base64 32
RELAYTERM_AUTH__SESSION_SIGNING_KEY_B64=CHANGE_ME_base64_32_bytes

# First-user bootstrap token. Required iff no user exists yet. Set
# this for the bootstrap window only, then unset and restart. After a
# user exists, `POST /api/v1/auth/bootstrap` returns 409.
#   openssl rand -base64 32 | tr '+/' '-_' | tr -d '='
RELAYTERM_AUTH__FIRST_USER_BOOTSTRAP_TOKEN=


# --- Backend: vault ---------------------------------------------------------

# The vault holds the per-identity AEAD-encrypted SSH private keys.
# Set `false` to disable; in that mode `POST /api/v1/ssh-identities`
# returns 503 until you wire one up.
RELAYTERM_VAULT__ENABLED=true

# 32 random bytes, base64. MUST be a different value from the session
# signing key.
#   openssl rand -base64 32
RELAYTERM_VAULT__MASTER_KEY_B64=CHANGE_ME_base64_32_bytes


# --- Backend: terminal recording -------------------------------------------

# Recording is OFF by default. Read `docs/terminal-recording.md`
# end-to-end (privacy posture in Section 7) before flipping this on.
RELAYTERM_TERMINAL_RECORDING__ENABLED=false

# Cleanup is INDEPENDENT of `RELAYTERM_TERMINAL_RECORDING__ENABLED`:
# turning recording off later MUST NOT make existing chunks immortal.
# These knobs are honoured even when recording itself is disabled.
RELAYTERM_TERMINAL_RECORDING__CLEANUP__ENABLED=true
# Stage A — one bounded sweep at boot, AFTER terminal-session
# reconciliation and BEFORE the listener binds. Default true; flip to
# false only if you want operator-driven cleanup exclusively.
# RELAYTERM_TERMINAL_RECORDING__CLEANUP__STARTUP_SWEEP_ENABLED=true
RELAYTERM_TERMINAL_RECORDING__CLEANUP__PERIODIC_SWEEP_ENABLED=true
# 1 hour between sweeps. Range: 60..=604800 (1 minute .. 1 week).
RELAYTERM_TERMINAL_RECORDING__CLEANUP__SWEEP_INTERVAL_SECONDS=3600
# Sessions purged per sweep tick. Range: 1..=10000.
RELAYTERM_TERMINAL_RECORDING__CLEANUP__BATCH_SIZE=250


# --- Backend: terminal session orchestration -------------------------------

# Detached-live-PTY TTL: how long a still-live SSH PTY lingers after
# every client has detached before the orchestrator reaps it. Reattach
# within this window resumes the same shell (sequence-replay); outside
# it the session is closed.
#
# SHORT-TERM RECONNECT GRACE WINDOW on a still-live PTY — NOT durable
# session resume. A backend restart drops every live PTY regardless of
# this value. Long-term persistent sessions are a separate, future
# architecture.
#
# Default 30 (historical baseline). Bounded 5..=86400 (5s..24h). Higher
# values consume backend RAM, file descriptors, and the SSH server's
# PTY budget for the full window — tune to your reconnect SLO and PTY
# budget. 300–1800s is a reasonable range when desktop/mobile
# reconnect after app restart matters.
# RELAYTERM_TERMINAL_SESSIONS__DETACHED_LIVE_PTY_TTL_SECONDS=30

# Per-user ceiling on concurrent live PTY runtimes (Phase 1B.1 quota —
# `docs/session-quotas.md` § 4.1). Counted against the in-memory
# orchestrator registry — both `active` and `detached` sessions count
# equally. A `POST /api/v1/terminal-sessions` that would exceed this
# ceiling is refused with `429 too_many_sessions`; the refusal writes
# no DB row and no audit event.
#
# Default 8 (conservative for solo homelab, defensible for small
# multi-user). Bounded 1..=256. Each live PTY consumes one russh
# channel, one target-host PTY, one in-memory replay buffer, and one
# or more tasks — pick the value that matches your concurrent
# workload, not your maximum hopeful concurrent shells.
# RELAYTERM_TERMINAL_SESSIONS__MAX_LIVE_PTY_SESSIONS_PER_USER=8

# Per-user ceiling on concurrent in-flight starting sessions (Phase
# 1B.2a quota — `docs/session-quotas.md` § 4.3). Counts the disjoint
# set of `Starting` placeholders that have NOT yet bound a live PTY,
# so it never double-counts the live cap. Defends against a runaway
# client that POSTs many sessions in flight without waiting for the
# PTY-start round-trip to complete. A `POST /api/v1/terminal-sessions`
# that would exceed this ceiling is refused with
# `429 too_many_starting_sessions`; same redaction posture as the
# live quota (no DB row, no audit event).
#
# Default 4 (enough for honest SPA burst behaviour — a navigation
# that opens a few sessions in parallel — but rejects a tight POST
# loop). Bounded 1..=32. The live quota is the load-bearing ceiling
# for resource consumption; this knob is defence-in-depth.
# RELAYTERM_TERMINAL_SESSIONS__MAX_STARTING_SESSIONS_PER_USER=4

# Deployment-wide ceiling on concurrent live PTY runtimes across ALL
# owners (Phase 1B.2b quota — `docs/session-quotas.md` § 4.2). Counted
# against THIS backend instance's in-memory registry — single-instance
# deployments are exact, multi-instance topologies enforce per-instance
# best-effort (§ 9). A `POST /api/v1/terminal-sessions` that would
# exceed this ceiling is refused with `429 too_many_sessions_deployment`;
# the refusal writes no DB row and no audit event. Deliberately NOT
# exposed via `GET /api/v1/config/session-policy` — operator-only,
# fingerprinting risk.
#
# Default 64 (conservative for single-tenant self-hosted; raise for
# multi-user homelab). Bounded 1..=4096. MUST be >= every per-user cap
# above (the validator rejects a per-user ceiling above the deployment
# ceiling).
# RELAYTERM_TERMINAL_SESSIONS__MAX_LIVE_PTY_SESSIONS_PER_DEPLOYMENT=64


# --- Tracing ---------------------------------------------------------------

# tracing-subscriber `EnvFilter` syntax. Default keeps the application
# at info, sqlx at warn, everything else at info.
RUST_LOG=relayterm=info,axum=info,sqlx=warn,info
