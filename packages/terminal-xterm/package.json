{
  "name": "@relayterm/terminal-xterm",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "sideEffects": [
    "./src/styles.ts",
    "**/*.css"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./styles": "./src/styles.ts"
  },
  "scripts": {
    "check": "tsc --noEmit -p tsconfig.json",
    "build": "tsc -p tsconfig.json --emitDeclarationOnly --declaration --outDir dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "echo \"no lint configured yet\""
  },
  "dependencies": {
    "@relayterm/terminal-core": "workspace:*",
    "@xterm/addon-fit": "0.10.0",
    "@xterm/addon-web-links": "0.11.0",
    "@xterm/xterm": "^5.5.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
